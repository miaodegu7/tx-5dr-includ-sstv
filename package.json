{
  "name": "tx-5dr",
  "version": "1.0.0",
  "description": "A modern digital radio station for amateur radio operators. Operate FT8, FT4, and voice modes from any web browser - anywhere, anytime.",
  "private": true,
  "main": "packages/electron-main/dist/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-runtime.js web",
    "dev:electron": "node scripts/dev-runtime.js electron",
    "build": "turbo run build",
    "preview": "yarn workspace @tx5dr/web preview",
    "electron": "yarn workspace @tx5dr/electron-main dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "package": "electron-builder --config electron-builder.config.cjs --dir",
    "package:mac": "electron-builder --config electron-builder.config.cjs --mac --arm64 --dir",
    "package:mac:x64": "electron-builder --config electron-builder.config.cjs --mac --x64 --dir",
    "make": "electron-builder --config electron-builder.config.cjs --publish never",
    "make:mac": "electron-builder --config electron-builder.config.cjs --mac --arm64 --publish never",
    "make:mac:x64": "electron-builder --config electron-builder.config.cjs --mac --x64 --publish never",
    "make:win": "electron-builder --config electron-builder.config.cjs --win --x64 --publish never",
    "make:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config electron-builder.config.cjs --mac --arm64 --publish never",
    "start": "yarn workspace @tx5dr/electron-main start",
    "build:package": "yarn build && yarn package",
    "build:make": "yarn build && yarn make",
    "clean": "node scripts/clean-paths.mjs out packages/*/dist",
    "check:i18n": "node scripts/check-i18n.mjs",
    "package:deb": "scripts/package-linux.sh deb",
    "package:rpm": "scripts/package-linux.sh rpm",
    "package:linux": "scripts/package-linux.sh both",
    "docker:build": "scripts/docker-quick-build.sh",
    "docker:build-multi": "scripts/build-docker.sh",
    "docker:build-and-push": "scripts/build-docker.sh boybook tx-5dr latest true",
    "generate:dxcc": "node scripts/generate-dxcc-data.mjs",
    "sync:cty": "node scripts/sync-cty-data.mjs",
    "make:autoupdate": "electron-builder --config electron-builder.config.cjs --publish never",
    "make:linux": "electron-builder --config electron-builder.config.cjs --linux --publish never"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "electron": "^36.4.0",
    "electron-builder": "26.8.1",
    "png-to-ico": "^2.1.8",
    "turbo": "^2.9.6"
  },
  "packageManager": "yarn@4.9.1",
  "optionalDependencies": {
    "segfault-handler": "^1.3.0"
  },
  "dependenciesMeta": {
    "hamlib": {
      "built": false
    }
  },
  "author": "BG5DRB <bg5drb@example.com>",
  "homepage": "https://tx5dr.com",
  "license": "MIT"
}
