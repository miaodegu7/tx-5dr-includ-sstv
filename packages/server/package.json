{
  "name": "@tx5dr/server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js",
    "./DigitalRadioEngine": "./dist/DigitalRadioEngine.js",
    "./cpu-profile": "./dist/services/ServerCpuProfileManager.js"
  },
  "scripts": {
    "build": "node ../../scripts/clean-paths.mjs dist && tsc",
    "dev": "node ../../scripts/run-with-env.mjs --node-env=development --glibc-tunables tsx watch --watch-path=src src/index.ts",
    "dev:prof": "node ../../scripts/run-with-env.mjs --node-env=development --glibc-tunables tsx --prof src/index.ts",
    "clinic:doctor": "yarn build && clinic doctor -- node dist/index.js",
    "clinic:flame": "yarn build && clinic flame -- node dist/index.js",
    "clinic:bubble": "yarn build && clinic bubbleprof -- node dist/index.js",
    "clinic:heap": "yarn build && clinic heapprofiler -- node dist/index.js",
    "dev:check-native": "tsx src/scripts/check-native-modules.ts",
    "start": "node ../../scripts/run-with-env.mjs --glibc-tunables node dist/scripts/server-launcher.js dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.1.0",
    "@openwebrx-js/api": "0.1.7",
    "@tx5dr/builtin-plugins": "workspace:*",
    "@tx5dr/contracts": "workspace:*",
    "@tx5dr/core": "workspace:*",
    "@tx5dr/plugin-api": "workspace:*",
    "@tx5dr/rigctld-server": "workspace:*",
    "@types/wav": "^1.0.4",
    "@types/ws": "^8.18.1",
    "audify": "patch:audify@npm%3A1.10.1#~/.yarn/patches/audify-npm-1.10.1-076cc4cf40.patch",
    "bcrypt": "^6.0.0",
    "eventemitter3": "^5.0.1",
    "fast-jwt": "^6.1.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "hamlib": "0.6.2",
    "icom-wlan-node": "0.5.1",
    "mic": "^2.1.2",
    "node-datachannel": "0.32.3",
    "node-forge": "^1.4.0",
    "node-wav": "^0.0.2",
    "onnxruntime-node": "^1.26.0",
    "rubato-fft-node": "^0.1.0",
    "serialport": "^13.0.0",
    "wav": "^1.0.2",
    "wsjtx-lib": "2.0.2",
    "xstate": "^5.23.0",
    "zod": "^3.25.30",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@statelyai/inspect": "^0.4.0",
    "@tx5dr/shared-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1",
    "@types/node-wav": "^0",
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
