{
  "name": "@tx5dr/builtin-plugins",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/build-ui.mjs",
    "dev:server": "tsc --watch",
    "dev:ui": "node scripts/build-ui.mjs --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tx5dr/contracts": "workspace:*",
    "@tx5dr/core": "workspace:*",
    "@tx5dr/plugin-api": "workspace:*",
    "node-forge": "^1.4.0"
  },
  "devDependencies": {
    "@tx5dr/shared-config": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.0.0",
    "vite": "^6.3.4",
    "vitest": "^1.0.0"
  }
}
